# Ollama configuration
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5-coder:7b

# LLM provider (ollama or google)
LLM_PROVIDER=ollama
GOOGLE_API_KEY=
GOOGLE_MODEL=gemma-4-26b-it
GOOGLE_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# Agent configuration
MAX_STEPS=8
MAX_TOOL_CALLS=15
LLM_TIMEOUT_SECONDS=120
LLM_TIMEOUT_ENABLED=false
TERMINAL_TIMEOUT_SECONDS=10
MAX_TOOL_OUTPUT_CHARS=12000

# Workspace paths
WORKSPACE_PATH=/workspace
SAFE_FILESYSTEM_ROOT=/workspace
HOST_ROOT=/hostroot
SERVICE_ROOT=/hostroot/root

# Server configuration
HOST=0.0.0.0
PORT=8000

# SSL/HTTPS (optional - for Tailscale)
USE_SSL=false
SSL_CERTFILE=
SSL_KEYFILE=

# Logging
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true

# Authentication
AUTH_ENABLED=true
API_KEYS_FILE=/root/.jarvis/api_keys.txt
SESSION_TIMEOUT_HOURS=24

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Optional features
ENABLE_STT=false
SKILLS_ENABLED=true
SKILLS_FILE=/root/.jarvis/skills.json
JARVIS_BASE_URL=http://127.0.0.1:8000
JARVIS_API_KEY=

# Tailscale (for Caddy)
TS-AUTHKEY=yourtailscaleauthkey


# Pentesting (hackai integration)
KALI_CONTAINER=kali
PENTEST_CONFIG=/workspace/pentest_config.yaml
PENTEST_LOGS_DIR=/workspace/pentest_logs
PENTEST_CONFIRM_THRESHOLD=7
PENTEST_CMD_TIMEOUT=120
