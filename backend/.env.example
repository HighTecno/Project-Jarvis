# Ollama Configuration
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5-coder:7b

# LLM Provider (ollama or google)
LLM_PROVIDER=ollama
GOOGLE_API_KEY=
GOOGLE_MODEL=gemma-4-26b-it
GOOGLE_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# Agent Configuration
MAX_STEPS=8
MAX_TOOL_CALLS=6
LLM_TIMEOUT_SECONDS=120
TERMINAL_TIMEOUT_SECONDS=10
MAX_TOOL_OUTPUT_CHARS=12000

# Workspace Configuration
WORKSPACE_PATH=/root/workspace
SAFE_FILESYSTEM_ROOT=/workspace

# Server Configuration
HOST=0.0.0.0
PORT=8000

# SSL/HTTPS Configuration (Tailscale)
USE_SSL=true
SSL_CERTFILE=/var/lib/tailscale/certs/your-tailscale-hostname.crt
SSL_KEYFILE=/var/lib/tailscale/certs/your-tailscale-hostname.key

# Optional feature flags
ENABLE_STT=false
SKILLS_ENABLED=true
SKILLS_FILE=/root/.jarvis/skills.json
JARVIS_BASE_URL=http://127.0.0.1:8000
JARVIS_API_KEY=

# Security Configuration
# Comma-separated list of allowed origins for CORS (leave empty to allow all - not recommended for production)
# Example: CORS_ORIGINS=https://jarvis.yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=
